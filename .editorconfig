# EditorConfig 是跨编辑器的代码风格协议：https://editorconfig.org/
# 任何打开本项目的编辑器（VSCode/WebStorm/Vim 等装了对应插件后）
# 都会自动按这里的规则配置缩进、换行符等基础格式。
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# TypeScript/JavaScript/JSON 等 NestJS 项目相关文件 → 2 空格
# 这跟项目里的 Prettier 默认值（tabWidth: 2）保持一致，避免冲突
[*.{ts,js,mjs,cjs,json,jsonc,yml,yaml,md}]
indent_style = space
indent_size = 2

# Makefile 必须用 Tab，不能改
[Makefile]
indent_style = tab
